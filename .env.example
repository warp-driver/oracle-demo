# oracle-demo environment.
#
# Bootstrap (run once per operator):
#
#   stellar keys generate oracle-deployer --fund --network testnet
#   stellar keys generate warpdrive-operator
#   export DEPLOYER_SECRET=$(stellar keys show oracle-deployer)
#   export DEPLOYER_ADDRESS=$(stellar keys address oracle-deployer)
#   export WARPDRIVE_SIGNING_MNEMONIC="$(stellar keys show warpdrive-operator --phrase)"

# Funded testnet payer. Signs contract deploys and acts as the node's
# Stellar aggregator credential (the key the node uses to submit
# `submit_round2` and `submit_final` transactions).
DEPLOYER_SECRET=
DEPLOYER_ADDRESS=

# BIP-39 mnemonic the warpdrive node HD-derives the operator's ed25519
# signing key from. MUST be a 12/24-word mnemonic — a raw hex secret
# can't satisfy the non-zero HD indices the engine uses.
WARPDRIVE_SIGNING_MNEMONIC=

# Optional — only for multi-operator deploys that pin service.json to IPFS.
# Generate at https://app.pinata.cloud → API Keys, scope `pinFileToIPFS`.
# PINATA_JWT=
