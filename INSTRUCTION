# ----- Triggering via MetaMask (Sepolia) -----
# Optional second entry point: instead of Freighter calling request_twap on
# Stellar, a MetaMask user calls TwapTrigger.request on Sepolia. Warp Drive
# bridges the ETH event into a request_twap on the same OracleContract.
#
# Prereqs: Foundry installed; Sepolia ETH in your dev wallet.
#
# export SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# export SEPOLIA_DEPLOYER_KEY=0x_your_funded_sepolia_secret
# task deploy-eth-trigger        # writes out/eth-trigger.json
# task wire-service              # uploads eth-bridge wasm + adds bridge workflow
# task frontend-config           # exposes eth-trigger.json to the UI
#
# Then connect MetaMask in the UI (switches to Sepolia automatically),
# click "Request via MetaMask (Sepolia)", sign the tx. Pipeline runs exactly
# like the Freighter path; UI shows the same Round 2 / Final progression.
