cd /home/u/work/warpdrive/oracle-demo

# ----- one-time prerequisites (skip if already installed) -----
# - stellar CLI, docker, jq, cargo (toolchain pinned in rust-toolchain.toml)
# - cargo install cargo-component
# - cargo install wkg
# - cargo install --path ../warpdrive/packages/cli --locked        # warpdrive-cli
# - cargo install --path ../warpdrive/packages/warpdrive --locked  # warpdrive node daemon
# - node 20+, yarn

# WIT deps (one-time per clone)
task fetch-wit

# ----- 1. Mint demo identities + write .env -----
./scripts/bootstrap-keys.sh > .env
set -a; source .env; set +a

# ----- 2. Phase 1: build everything + deploy on-chain contracts -----
task deploy
# -> out/deploy.json    (ed25519_security, ed25519_verification, project_root)
# -> out/oracle.json    (the handler contract, default quorum 4/5)
# Also runs register_handler on project_root.

# ----- 3. Start the warpdrive node in another terminal -----
#   cd /home/u/work/warpdrive/oracle-demo
#   set -a; source .env; set +a
#   task run-node
# Wait for "Stellar chain [stellar:testnet] is healthy". Leave it running.

# ----- 4. Phase 2: upload components, build service.json, register with node -----
task wire-service
# -> out/{cron,twap,median,aggregator}.digest
# -> service/service.json
# -> out/service.hash
# Node log: "Initializing dispatcher: services=1, workflows=3, components=4"

# ----- 5. Register the operator's pubkey + threshold (default 1/1) -----
task register-signer
# Drops stale signers from previous service-registration cycles, fetches
# the current node's pubkey, adds it at weight SIGNER_WEIGHT (default 100),
# sets THRESHOLD_NUM/THRESHOLD_DEN (default 1/1).

# ----- 6. Hand the oracle contract id to the frontend, then run the UI -----
task frontend-config
task frontend-dev    # http://localhost:5173

# Done. The node is now:
# - polling CoinGecko every 30s (fetch_prices workflow; CRON_SCHEDULE override)
# - watching OracleContract for "twapreq" events (compute_twap workflow)
# - watching OracleContract for "r2ready" events (compute_median workflow)
#
# Use the UI to call request_twap(asset, range_secs); within ~10–20 s
# you should see Round2Ready, then Finalized.

