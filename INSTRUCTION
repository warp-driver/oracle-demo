cd /home/u/work/warpdrive/oracle-demo

# ----- one-time prerequisites (skip if already installed) -----
# - stellar CLI, docker, jq, cargo (toolchain pinned in rust-toolchain.toml)
# - cargo install cargo-component
# - cargo install wkg
# - cargo install --path ../warpdrive/packages/cli --locked        # warpdrive-cli
# - cargo install --path ../warpdrive/packages/warpdrive --locked  # warpdrive node daemon
# - node 20+, yarn

# WIT deps (one-time per clone)
task fetch-wit

# ----- 1. Mint deployer + 2 operator mnemonics, write .env -----
./scripts/bootstrap-keys.sh > .env
set -a; source .env; set +a

# ----- 2. Phase 1: build contracts + components, deploy on-chain stack -----
task deploy
# -> out/deploy.json   (ed25519_security, ed25519_verification, project_root)
# -> out/oracle.json   (the handler — quorum defaults to 1/1 = "all operators")

# ----- 3. SECOND TERMINAL — operator 1 (port 8000) -----
#   cd /home/u/work/warpdrive/oracle-demo
#   set -a; source .env; set +a
#   task run-node
# Wait for "Stellar chain [stellar:testnet] is healthy"
# and "HTTP server bound to port 8000". Leave running.

# ----- 4. THIRD TERMINAL — operator 2 (port 8010) -----
#   cd /home/u/work/warpdrive/oracle-demo
#   set -a; source .env; set +a
#   OP=2 task run-node
# HTTP :8010, p2p :9010, data dir out/node-data-2.

# ----- 5. Phase 2: upload to BOTH nodes + build/activate service -----
task wire-service
# -> out/{cron,twap,median,aggregator}.digest
# -> service/service.json
# -> out/service.hash
# Each node's log: "Initializing dispatcher: services=1, workflows=3, components=4"
# (workflows=4, components=5 once the optional Sepolia bridge below is wired up)

# ----- 6. Sync both operators' pubkeys on chain + apply threshold -----
task register-signers
# Walks OP=1..OPERATORS, drops anything not in the resulting set,
# adds the rest at SIGNER_WEIGHT=100, sets threshold 1/1 (=all-weight).

# ----- 7. Frontend config + UI -----
task frontend-config
task frontend-dev    # http://localhost:5173

# Done. Both nodes are now:
# - polling CoinGecko every 30 s (fetch_prices; CRON_SCHEDULE override)
# - watching OracleContract for "twapreq" events (compute_twap)
# - watching OracleContract for "r2ready" events (compute_median)
#
# Submit a TWAP request from the UI; within ~10–20 s the Round 2 bundle
# fills to 2/2, Round2Ready fires, then Finalized lands with the
# quorum-signed median.

